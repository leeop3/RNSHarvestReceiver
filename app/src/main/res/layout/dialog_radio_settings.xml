<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Fixed frequency -->
    <TextView
        android:id="@+id/freqText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Frequency: 433.025 MHz (fixed)"
        android:textColor="@color/accent_green"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:padding="10dp"
        android:background="@color/header_bg"
        android:layout_marginBottom="16dp" />

    <!-- Bandwidth -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Bandwidth" android:textColor="@color/text_secondary"
        android:textSize="12sp" android:layout_marginBottom="4dp" />
    <Spinner
        android:id="@+id/bwSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/spinner_bg"
        android:layout_marginBottom="16dp" />

    <!-- Spreading Factor -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Spreading Factor (7–12)" android:textColor="@color/text_secondary"
        android:textSize="12sp" android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/sfEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="number"
        android:textColor="@color/text_primary"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- Coding Rate -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Coding Rate denominator (5=4/5, 6=4/6, 7=4/7, 8=4/8)"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/crEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="number"
        android:textColor="@color/text_primary"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- TX Power -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TX Power in dBm (0–17)" android:textColor="@color/text_secondary"
        android:textSize="12sp" android:layout_marginBottom="4dp" />
    <EditText
        android:id="@+id/txEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="number"
        android:textColor="@color/text_primary"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/radioStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/accent_amber"
        android:textSize="11sp"
        android:padding="8dp" />

</LinearLayout>
