<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <!-- Top row: hop indicator + name + LXMF badge + count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:id="@+id/hopIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/nodeNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Node 1a2b3c4d…"
                android:textColor="@color/accent_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/lxmfBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LXMF"
                android:textColor="@color/accent_amber"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_outline_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/nodeCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×1"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Address hash -->
        <TextView
            android:id="@+id/nodeHashText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0000000000000000000"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Aspect + hops + last seen row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/nodeAspectText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="lxmf.delivery"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/nodeHopsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Direct"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/nodeLastSeenText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Just now"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
