<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp">

        <!-- Row 1: dot + name + LXMF badge + nick badge + count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp">

            <View
                android:id="@+id/hopIndicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/nodeNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- Nickname badge -->
            <TextView
                android:id="@+id/nickBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✎"
                android:textColor="@color/accent_green"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!-- LXMF badge -->
            <TextView
                android:id="@+id/lxmfBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LXMF"
                android:textColor="@color/accent_amber"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_outline_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/nodeCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 2: hash -->
        <TextView
            android:id="@+id/nodeHashText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Row 3: aspect + hops + last seen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/nodeAspectText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/nodeHopsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/nodeLastSeenText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Tap hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to set nickname · Long-press to copy address"
            android:textColor="@color/text_hint"
            android:textSize="9sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

</LinearLayout>
