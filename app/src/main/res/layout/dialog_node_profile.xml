<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Hash -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADDRESS"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp" />
    <TextView
        android:id="@+id/profileHashText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0000000000000000000000000000000000000000"
        android:textColor="@color/accent_green"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:background="@color/header_bg"
        android:padding="8dp"
        android:layout_marginBottom="12dp" />

    <!-- Aspect -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ASPECT"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="2dp" />
    <TextView
        android:id="@+id/profileAspectText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <!-- Hops + count row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOPS"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/profileHopsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_green"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANNOUNCES"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/profileCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Nickname -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NICKNAME (shown in Incoming &amp; Summary)"
        android:textColor="@color/text_hint"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/profileNickEdit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. Ahmad, Harvester-A1"
        android:inputType="textPersonName|textCapWords"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/spinner_bg"
        android:paddingHorizontal="12dp"
        android:textSize="14sp" />

</LinearLayout>
