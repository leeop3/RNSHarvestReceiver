<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Date navigator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/prevDateBtn"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/accent_green"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Previous date" />

        <TextView
            android:id="@+id/dateLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Today"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/nextDateBtn"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_media_next"
            android:tint="@color/accent_green"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="Next date" />

    </LinearLayout>

    <!-- Totals banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/header_bg"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp">

        <TextView android:id="@+id/totalRipeText"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:textColor="@color/accent_green" android:textSize="12sp"
            android:fontFamily="monospace" />
        <TextView android:id="@+id/totalEmptyText"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:fontFamily="monospace" />
        <TextView android:id="@+id/totalReportsText"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:textColor="@color/accent_amber" android:textSize="12sp"
            android:fontFamily="monospace" />
        <TextView android:id="@+id/harvesterCountText"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:textColor="@color/text_hint" android:textSize="11sp" />

    </LinearLayout>

    <!-- Column headers -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="32dp"
        android:orientation="horizontal" android:background="@color/header_bg_dark"
        android:paddingHorizontal="12dp" android:gravity="center_vertical">

        <TextView android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="RNK" style="@style/ColumnHeader" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.3" android:text="HARVESTER" style="@style/ColumnHeader" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.8" android:text="RIPE" style="@style/ColumnHeader"
            android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.8" android:text="EMPTY" style="@style/ColumnHeader"
            android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.8" android:text="TOTAL" style="@style/ColumnHeader"
            android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.1" android:text="EFFICIENCY" style="@style/ColumnHeader"
            android:gravity="end" />

    </LinearLayout>

    <!-- List -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout android:id="@+id/emptyState"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="42sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="No data for this date"
                android:textColor="@color/text_secondary" android:textSize="15sp"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </FrameLayout>

</LinearLayout>
