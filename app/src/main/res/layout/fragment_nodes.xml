<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <TextView
            android:id="@+id/nodeCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 node(s) discovered"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/text_hint"
            android:textColor="@color/text_hint" />

    </LinearLayout>

    <!-- Connection hint -->
    <TextView
        android:id="@+id/connectionHintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ Connect to RNode to discover nearby nodes"
        android:textColor="@color/accent_amber"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@color/header_bg"
        android:visibility="visible" />

    <!-- Node list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="48sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No nodes discovered yet"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nodes announce themselves automatically when they power on or send data. Make sure your RNode is connected and radio parameters match the network."
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="32dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
