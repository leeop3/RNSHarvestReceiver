<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ── THIS APP'S OWN ADDRESS ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_primary_dark"
        android:paddingHorizontal="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS RECEIVER'S ADDRESS"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/ownAddressText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="generating…"
                android:textColor="@color/accent_green"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.05" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/copyAddressBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="COPY"
                android:textSize="11sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent_green"
                android:textColor="@color/accent_green" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Key this address into field harvesters as their LXMF destination"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- ── CONNECTION HINT ────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/connectionHintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ Connect to RNode to discover nearby nodes"
        android:textColor="@color/accent_amber"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@color/header_bg"
        android:visibility="visible" />

    <!-- ── DISCOVERED NODES HEADER ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/nodeCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 node(s) discovered"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearBtn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Clear"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/text_hint" />

    </LinearLayout>

    <!-- ── NODES LIST ─────────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No nodes discovered yet"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nodes announce when they power on or transmit.\nEnsure radio parameters match the network."
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:textAlignment="center"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="32dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── RAW FRAME LOG (debug) ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_primary_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RAW FRAME LOG"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearLogBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Clear"
                android:textSize="10sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_hint" />

        </LinearLayout>

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/bg_primary"
            android:paddingHorizontal="14dp">

            <TextView
                android:id="@+id/rawLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="(no frames yet)"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:paddingVertical="6dp" />

        </ScrollView>

    </LinearLayout>

</LinearLayout>
