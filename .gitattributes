# Gradle wrapper - must be executable on Linux/macOS runners
gradlew        text eol=lf
gradlew.bat    text eol=crlf

# Force LF line endings for shell scripts
*.sh           text eol=lf

# Android / Java sources
*.kt           text eol=lf
*.java         text eol=lf
*.xml          text eol=lf
*.gradle       text eol=lf
*.properties   text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.pro          text eol=lf

# Binary files - no line ending conversion
*.apk          binary
*.aar          binary
*.jks          binary
*.keystore     binary
*.jar          binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
